# Railway PostgreSQL
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# SMTP (비밀번호 재설정 메일 전송용 — 미설정 시 콘솔 로그로 fallback)
# Gmail 예: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
# 비밀번호는 Google 계정 > 앱 비밀번호에서 발급 (2FA 필요)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="My D-day <no-reply@mydday.app>"
